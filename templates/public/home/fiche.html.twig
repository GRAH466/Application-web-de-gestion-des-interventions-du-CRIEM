{% extends 'public/base.html.twig' %}

{% block title %}Fiche de Demande{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('fiche.css') }}">
{% endblock %}


{% block body %}
<!-- Bouton Retour en haut à gauche -->
<div class="back-button-container">
    <a href=" {{ path('Accueil') }}" class="btn-back">
        <i class="bi bi-arrow-left me-1"></i>Retour
    </a>
</div>
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg">
                <div class="card-header bg-primary text-white text-center py-4">
                    <h2 class="mb-0"><i class="bi bi-clipboard-plus me-2"></i>Fiche de Demande</h2>
                </div>
                <div class="card-body p-5">
                    {# Messages flash #}
                    {% for message in app.flashes('success') %}
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i>{{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endfor %}
                    {% for message in app.flashes('error') %}
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>{{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endfor %}

                    {# Formulaire #}
                    <form method="post" class="needs-validation" novalidate>
                        {# Date de demande #}
                        <div class="mb-4">
                            <label for="date_dem" class="form-label fw-bold">📅 Date de Demande</label>
                            <input type="date" class="form-control form-control-lg" id="date_dem" name="date_dem" required>
                            <div class="invalid-feedback">Veuillez saisir une date de demande.</div>
                        </div>

                        {# Urgence #}
                        <div class="mb-4">
                            <label for="urg" class="form-label fw-bold">🚨 Niveau d'Urgence</label>
                            <select class="form-select form-select-lg" id="urg" name="urg" required>
                                <option value="" disabled selected>Choisissez le niveau d'urgence</option>
                                <option value="Faible">Faible</option>
                                <option value="Moyenne">Moyenne</option>
                                <option value="Élevée">Élevée</option>
                                <option value="Critique">Critique</option>
                            </select>
                            <div class="invalid-feedback">Veuillez sélectionner un niveau d'urgence.</div>
                        </div>

                        {# Description #}
                        <div class="mb-4">
                            <label for="descr" class="form-label fw-bold">📝 Description</label>
                            <textarea class="form-control form-control-lg" id="descr" name="descr" rows="4" 
                                      placeholder="Décrivez votre demande en détail..." required></textarea>
                            <div class="invalid-feedback">Veuillez saisir une description.</div>
                        </div>

                        {# Signature structure #}
                        <div class="mb-4">
                            <label for="sign_struc" class="form-label fw-bold">✍️ Signature de la Structure</label>
                            <input type="text" class="form-control form-control-lg" id="sign_struc" name="sign_struc" 
                                   placeholder="Nom du signataire" required>
                            <div class="invalid-feedback">Veuillez saisir une signature.</div>
                        </div>

                        {# Nom structure #}
                        <div class="mb-4">
                            <label for="Nom_structure" class="form-label fw-bold">🏢 Nom de la Structure</label>
                            <input type="text" class="form-control form-control-lg" id="Nom_structure" name="Nom_structure" 
                                   placeholder="Nom de votre structure" required>
                            <div class="invalid-feedback">Veuillez saisir le nom de la structure.</div>
                        </div>

                        {# Bouton de soumission #}
                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg py-3">
                                <i class="bi bi-send-check-fill me-2"></i>Envoyer la Demande
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('fiche.js') }}"></script>
{% endblock %}