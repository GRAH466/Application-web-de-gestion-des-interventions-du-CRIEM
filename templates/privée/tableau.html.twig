{% extends 'privée/tableaudebord.html.twig' %}

{% block title %}Tableau de Bord - CRIEM{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('tableau.css') }}">
{% endblock %}

{% block body %}
</head>
<body>
    <header class="dashboard-header">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h1>Tableau de Bord des Activités de Maintenance</h1>
                    <p class="lead">Centre Régional des Infrastructures de L'Equipement et de la Maintenance - Yamoussoukro</p>
                </div>
                <div class="col-md-4 text-md-end">
                    <div class="btn-group">
                        <button class="btn btn-outline-light" id="exportPdf">Exporter PDF</button>
                        <button class="btn btn-outline-light" id="changeView">Voir les commandes</button>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <div class="container">
        <!-- Sélecteur d'année -->
        <div class="row year-selector">
            <div class="col-md-12">
                <div class="d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">Sélection de l'année:</h4>
                    <div class="btn-group" role="group" aria-label="Sélection d'année">
                        <button type="button" class="btn btn-outline-light year-btn active" data-year="2024">2024</button>
                        <button type="button" class="btn btn-outline-light year-btn" data-year="2023">2023</button>
                        <button type="button" class="btn btn-outline-light year-btn" data-year="2022">2022</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filtres -->
        <div class="row filter-section">
            <div class="col-md-3">
                <label for="monthFilter" class="form-label">Mois</label>
                <select class="form-select" id="monthFilter">
                    <option value="all">Tous les mois</option>
                    <option value="0">Janvier</option>
                    <option value="1">Février</option>
                    <option value="2">Mars</option>
                    <option value="3">Avril</option>
                    <option value="4">Mai</option>
                    <option value="5">Juin</option>
                    <option value="6">Juillet</option>
                    <option value="7">Août</option>
                    <option value="8">Septembre</option>
                    <option value="9">Octobre</option>
                    <option value="10">Novembre</option>
                    <option value="11">Décembre</option>
                </select>
            </div>
            <div class="col-md-3">
                <label for="specialtyFilter" class="form-label">Spécialité</label>
                <select class="form-select" id="specialtyFilter">
                    <option value="all">Toutes les spécialités</option>
                    <option value="bio">Biomédical</option>
                    <option value="info">Informatique</option>
                    <option value="plomb">Plomberie</option>
                    <option value="elect">Électricité</option>
                    <option value="menui">Menuiserie</option>
                    <option value="froid">Froid</option>
                    
                </select>
            </div>
            <div class="col-md-3">
                <label for="typeFilter" class="form-label">Type d'intervention</label>
                <select class="form-select" id="typeFilter">
                    <option value="all">Tous les types</option>
                    <option value="preventive">Préventive</option>
                    <option value="curative">Curative</option>
                    <option value="installation">Installation</option>
                </select>
            </div>
            <div class="col-md-3 d-flex align-items-end">
                <button class="btn btn-primary w-100" id="applyFilters">Appliquer les filtres</button>
            </div>
        </div>

        <!-- KPI Cards -->
        <div class="row">
            <div class="col-md-3">
                <div class="card kpi-card">
                    <div class="kpi-value" id="totalInterventions">0</div>
                    <div class="kpi-label">Interventions Total</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card kpi-card">
                    <div class="kpi-value" id="preventiveRate">0%</div>
                    <div class="kpi-label">Taux de Préventives</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card kpi-card">
                    <div class="kpi-value" id="executionRate">0%</div>
                    <div class="kpi-label">Taux d'Exécution</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card kpi-card">
                    <div class="kpi-value" id="avgResolution">0h</div>
                    <div class="kpi-label">Temps Moyen Résolution</div>
                </div>
            </div>
        </div>

        <!-- Navigation tabs -->
        <ul class="nav nav-tabs mb-4" id="dashboardTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="overview-tab" data-bs-toggle="tab" data-bs-target="#overview" type="button" role="tab">Aperçu</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="monthly-tab" data-bs-toggle="tab" data-bs-target="#monthly" type="button" role="tab">Activités Mensuelles</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="specialty-tab" data-bs-toggle="tab" data-bs-target="#specialty" type="button" role="tab">Par Spécialité</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="section-tab" data-bs-toggle="tab" data-bs-target="#section" type="button" role="tab">Par Section</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="planning-tab" data-bs-toggle="tab" data-bs-target="#planning" type="button" role="tab">Planification</button>
            </li>
        </ul>

        <!-- Tab content -->
        <div class="tab-content" id="dashboardTabsContent">
            <!-- Overview Tab -->
            <div class="tab-pane fade show active" id="overview" role="tabpanel">
                <div class="row">
                    <div class="col-md-8">
                        <div class="card">
                            <div class="card-header">Évolution des Interventions par Mois</div>
                            <div class="card-body">
                                <div class="chart-container">
                                    <canvas id="monthlyTrendChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card">
                            <div class="card-header">Répartition par Type</div>
                            <div class="card-body">
                                <div class="chart-container">
                                    <canvas id="typeDistributionChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header">Top Spécialités</div>
                            <div class="card-body">
                                <div class="chart-container">
                                    <canvas id="specialtyChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header">Taux d'Exécution par Spécialité</div>
                            <div class="card-body">
                                <div class="chart-container">
                                    <canvas id="executionChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Monthly Activities Tab -->
            <div class="tab-pane fade" id="monthly" role="tabpanel">
                <div class="card">
                    <div class="card-header">Détail des Activités Mensuelles</div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped table-hover" id="monthlyTable">
                                <thead>
                                    <tr>
                                        <th>Mois</th>
                                        <th>Biomédical</th>
                                        <th>Informatique</th>
                                        <th>Plomberie</th>
                                        <th>Électricité</th>
                                        <th>Menuiserie</th>
                                        <th>Froid</th>
                                        <th>Mécanique</th>
                                        <th>Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Data will be populated by JavaScript -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Specialty Tab -->
            <div class="tab-pane fade" id="specialty" role="tabpanel">
                <div class="row">
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header">Interventions par Spécialité</div>
                            <div class="card-body">
                                <div class="chart-container">
                                    <canvas id="specialtyDetailChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header">Répartition des Types par Spécialité</div>
                            <div class="card-body">
                                <div class="chart-container">
                                    <canvas id="specialtyTypeChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="card mt-4">
                    <div class="card-header">Détail par Spécialité</div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped" id="specialtyTable">
                                <thead>
                                    <tr>
                                        <th>Spécialité</th>
                                        <th>Préventives</th>
                                        <th>Curatives</th>
                                        <th>Installations</th>
                                        <th>Total</th>
                                        <th>Taux d'Exécution</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Data will be populated by JavaScript -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Section Tab -->
            <div class="tab-pane fade" id="section" role="tabpanel">
                <div class="row">
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header">Répartition par Section</div>
                            <div class="card-body">
                                <div class="chart-container">
                                    <canvas id="sectionChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header">Centres de Santé par District</div>
                            <div class="card-body">
                                <div class="chart-container">
                                    <canvas id="healthCentersChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="card mt-4">
                    <div class="card-header">Informations des Districts Sanitaires</div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped" id="districtsTable">
                                <thead>
                                    <tr>
                                        <th>District Sanitaire</th>
                                        <th>Population</th>
                                        <th>Superficie (km²)</th>
                                        <th>Formations Sanitaires</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Data will be populated by JavaScript -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Planning Tab -->
            <div class="tab-pane fade" id="planning" role="tabpanel">
                <div class="card">
                    <div class="card-header">Planification vs Réalisation</div>
                    <div class="card-body">
                        <div class="chart-container">
                            <canvas id="planningChart"></canvas>
                        </div>
                    </div>
                </div>
                
                <div class="card mt-4">
                    <div class="card-header">Bilan des Activités - DIEMP</div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-striped" id="diempTable">
                                <thead>
                                    <tr>
                                        <th>Spécialité</th>
                                        <th>Maintenances Préventives Prévues</th>
                                        <th>Maintenances Préventives Réalisées</th>
                                        <th>Taux d'Exécution</th>
                                        <th>Pannes Relevées</th>
                                        <th>Maintenances Curatives Réalisées</th>
                                        <th>Taux d'Exécution Curatives</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Data will be populated by JavaScript -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        
        
            
        </div>
    </div>
    </body>
    {% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('tableau.js') }}"></script>
{% endblock %}